module Vajra
  class Error < StandardError
  end

  interface _ConfigTarget
    def instance_eval: () { () -> void } -> void
  end

  VERSION: String

  def self.header: () -> String
  def self.configure: () { (_ConfigTarget) -> void } -> void
                     | () { () -> void } -> void
  def self.start: (
    ?host: String,
    ?port: Integer,
    ?bind: String,
    ?unix_socket: String,
    ?backlog: Integer,
    ?reuse_port: bool,
    ?workers: Integer,
    ?threads: [Integer] | [Integer, Integer],
    ?preload_app: bool,
    ?worker_boot_timeout: Integer,
    ?worker_shutdown_timeout: Integer,
    ?queue_capacity: Integer,
    ?scheduler_policy: String,
    ?max_request_head_bytes: Integer,
    ?request_timeout: Integer,
    ?first_data_timeout: Integer,
    ?persistent_timeout: Integer,
    ?max_request_body_bytes: Integer,
    ?request_head_timeout: Integer,
    ?request_body_timeout: Integer,
    ?keepalive_timeout: Integer,
    ?max_keepalive_requests: Integer,
    ?linger_timeout: Integer,
    ?max_connections: Integer,
    ?max_requests_per_worker: Integer,
    ?worker_timeout: Integer,
    ?tls: bool,
    ?tls_certificate: String,
    ?tls_private_key: String,
    ?tls_ca_certificate: String,
    ?tls_verify_mode: String,
    ?tls_min_version: String,
    ?alpn_protocols: Array[String],
    ?http2: bool,
    ?http2_max_concurrent_streams: Integer,
    ?http2_initial_window_size: Integer,
    ?http2_max_frame_size: Integer,
    ?http2_header_table_size: Integer,
    ?log_level: String,
    ?access_log: String,
    ?error_log: String,
    ?structured_logs: bool,
    ?stats_path: String,
    ?metrics_endpoint: String,
    ?pidfile: String,
    ?state_path: String,
    ?control_socket: String,
    ?drain_timeout: Integer,
    ?shutdown_timeout: Integer,
    ?phased_restart: bool
  ) -> nil
  def self.stop: () -> nil
end
