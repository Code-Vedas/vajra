module Vajra
  class Error < StandardError
  end

  VERSION: String

  def self.header: () -> String
  def self.install_optional_railtie: () -> bool?
  def self.configure: [T, R] () { (T) -> R } -> R
                     | [T, R] () { (?T) -> R } -> R
                     | [T, R] () { (*T) -> R } -> R
                     | [R] () { () -> R } -> R
  def self.start: (
    ?host: String,
    ?port: Integer,
    ?workers: Integer,
    ?threads: [Integer] | [Integer, Integer],
    ?max_connections: Integer,
    ?socket_queue_capacity: Integer,
    ?max_request_head_bytes: Integer,
    ?request_timeout: Integer,
    ?first_data_timeout: Integer,
    ?persistent_timeout: Integer,
    ?worker_timeout: Integer,
    ?request_head_timeout: Integer,
    ?log_level: String,
    ?access_log: String?,
    ?error_log: String?,
    ?structured_logs: bool?,
    ?access_log_format: String?,
    ?stats_path: String?,
    ?metrics_endpoint: String?,
    ?trace_enabled: bool?,
    ?trace_endpoint: String?,
    ?trace_service_name: String?,
    ?trace_otel_owner: bool?
  ) -> nil
  def self.stop: () -> nil
end
