module Vajra
  module Internal
    module Tracing
      type start_option_value =
        Integer |
        String |
        bool |
        Array[String] |
        Array[Integer] |
        nil

      type start_options = Hash[Symbol, start_option_value]

      type rack_env_value =
        String |
        bool |
        IO |
        StringIO |
        Array[Integer]

      type lifecycle_event_key =
        :event |
        :worker_index |
        :pid |
        :lifecycle_state |
        :health_state |
        :recovery_state |
        :available |
        :exit_classification |
        :replacement_needed |
        :terminal_replacement_failure |
        :exit_detail |
        :timestamp

      type lifecycle_event = Hash[
        lifecycle_event_key,
        String | Integer | bool
      ]

      type native_request_event_key =
        :method |
        :target |
        :status |
        :duration_nanoseconds |
        :bytes_written |
        :remote_addr |
        :protocol |
        :host |
        :user_agent |
        :referer |
        :request_id |
        :worker_pid |
        :worker_index |
        :connection_outcome |
        :trace_id |
        :span_id |
        :outcome |
        :failure_kind |
        :response_sent |
        :error_message |
        :timestamp

      type native_request_event = Hash[
        native_request_event_key,
        String | Integer | bool | nil
      ]

      type trace_context = Hash[Symbol, String?]

      interface _Tracer
        def in_span: [T] (String, attributes: Hash[String, String | Integer | bool]) { () -> T } -> T
      end

      interface _TraceContext
        def hex_trace_id: () -> String?
        def trace_id: () -> String?
        def hex_span_id: () -> String?
        def span_id: () -> String?
      end

      interface _TraceSpan
        def context: () -> _TraceContext?
      end

      interface _TelemetryProvider
        def tracer: (String) -> _Tracer?
        def force_flush: () -> void
        def shutdown: () -> void
      end

      interface _MeterProvider
        def meter: (String) -> _Meter?
      end

      type metric_instrument = _AddInstrument | _RecordInstrument

      interface _Meter
        def create_counter: (String, ?unit: String) -> metric_instrument?
        def create_histogram: (String, ?unit: String) -> metric_instrument?
        def create_up_down_counter: (String, ?unit: String) -> metric_instrument?
      end

      interface _AddInstrument
        def add: (Numeric, attributes: Hash[String, String | Integer | bool]) -> void
      end

      interface _RecordInstrument
        def record: (Numeric, attributes: Hash[String, String | Integer | bool]) -> void
      end

      class TraceConfig < ::Struct[bool | String]
        attr_accessor enabled: bool
        attr_accessor endpoint: String
        attr_accessor service_name: String
        attr_accessor otel_owner: bool
        attr_accessor traces_exporter: String
        attr_accessor metrics_exporter: String
        attr_accessor propagators: String
        attr_accessor resource_attributes: String
        attr_accessor sampler: String
        attr_accessor sampler_arg: String
      end

      class TraceState < ::Struct[
        bool |
        String |
        _Tracer? |
        _Meter? |
        _TelemetryProvider? |
        metric_instrument? |
        Hash[Symbol, metric_instrument?] |
        Thread?
      ]
        attr_accessor enabled: bool
        attr_accessor available: bool
        attr_accessor tracer: _Tracer?
        attr_accessor meter: _Meter?
        attr_accessor provider: _TelemetryProvider?
        attr_accessor warning_emitted: bool
        attr_accessor request_counter: metric_instrument?
        attr_accessor request_duration: metric_instrument?
        attr_accessor active_requests: metric_instrument?
        attr_accessor metric_instruments: Hash[Symbol, metric_instrument?]
        attr_accessor request_observability_thread: Thread?
        attr_accessor request_observability_stop: bool
        attr_accessor propagators: String
      end

      class RequestSpanObservabilityState < ::Struct[bool]
        attr_accessor active: bool
      end

      TRACE_MUTEX: Thread::Mutex
      TRACE_STATE: TraceState
      REQUEST_SPAN_OBSERVABILITY_STATE: RequestSpanObservabilityState

      def self.install_from_start_options!: (start_options) -> bool
      def self.shutdown!: () -> void
      def self.after_fork!: () -> void
      def self.with_request_span: [T] (Hash[String, rack_env_value]) { () -> T } -> T
      def self.current_trace_context: (?_TraceSpan? span) -> trace_context
      def self.emit_lifecycle_span: (lifecycle_event) -> nil
      def self.emit_native_request_span: (native_request_event) -> void
      def self.__native_set_tracing_status__: (bool, bool, String, String, bool, Float, String, String) -> nil
      def self.__native_set_lifecycle_callback__: ((Method | Proc)? callback) -> ((Method | Proc)?)
      def self.__native_set_request_observability_callback__: ((Method | Proc)? callback) -> ((Method | Proc)?)
      def self.__native_drain_request_observability_events__: (Integer limit) -> Array[native_request_event]
    end
  end
end
