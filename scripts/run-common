set -eu

if [ "${SCRIPT_DIR:-}" = "" ]; then
  SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
fi

if [ "${REPO_ROOT:-}" = "" ]; then
  REPO_ROOT=$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)
fi

TMP_DIR="${REPO_ROOT}/tmp/run-all"
mkdir -p "${TMP_DIR}"

suite_name() {
  basename "$1"
}

ruby_suites() {
  cat <<'EOF'
gems/vajra
EOF
}

run_cmd() {
  name="$1"
  shift
  log_file="${TMP_DIR}/${name}.log"

  echo "==> ${name}"
  if "$@" >"${log_file}" 2>&1; then
    tail -n 20 "${log_file}" | sed '/^[[:space:]]*$/d' | tail -n 8 || true
    echo
    rm -f "${log_file}"
    return 0
  fi

  echo "-- ${name} failed --"
  cat "${log_file}"
  return 1
}
